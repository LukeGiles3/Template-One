---
import Footer from "../components/footer/footer.astro"
import Header from "../components/header/header.astro"
import HeroContainer from "../components/hero/heroContainer.astro"
import AboutSection from "../components/sections/aboutSection.astro"
import ServicesSection from "../components/sections/servicesSection.astro"
import Form from "../components/form/form.astro"
import TestimonialsSection from "../components/sections/testimonialsSection.astro"
import PageLayout from "../layouts/PageLayout.astro"
import siteContent from "../data/site-content.json"
---

<PageLayout title={siteContent.pages.home.title} description={siteContent.pages.home.description}>
  <Header />
  <HeroContainer />
  <AboutSection />
  <ServicesSection />
  <Form />
  <TestimonialsSection />
  <Footer />
</PageLayout>

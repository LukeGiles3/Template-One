---
import { Image } from "astro:assets";
import siteContent from "../../data/site-content.json";
import { getAssetByPath } from "../../utils/getAssetByPath";

const servicesContent = siteContent.components.sections.servicesSection;
const serviceItems = servicesContent.items.map((item) => ({
  ...item,
  imageAsset: getAssetByPath(item.image),
}));
---

<section class="servicesSection">
  <div class="servicesSectionInner">
    <header class="servicesSectionHeader">
      <h2>{servicesContent.heading}</h2>
      <div class="servicesDivider" aria-hidden="true">
        <span class="servicesDividerLine"></span>
        <span class="servicesDividerLeaf"></span>
        <span class="servicesDividerLine"></span>
      </div>
    </header>

    <div class="servicesGrid">
      {serviceItems.map((item) => (
        <article class="serviceCard">
          <div class="serviceCardImageWrap">
            <Image
              class="serviceCardImage"
              src={item.imageAsset}
              width={720}
              alt={item.imageAlt}
              loading="lazy"
              decoding="async"
            />
          </div>
          <h3>{item.title}</h3>
        </article>
      ))}
    </div>
  </div>
</section>
